@page "/video"
@inject HttpClient Http
@rendermode InteractiveServer

<PageTitle>TürkAI — Video Insights</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4">🎬 Travel Video Insights</h2>
    <p class="text-muted">
        Submit any Turkey travel video URL (MP4 or YouTube). TürkAI uses Azure Video Indexer
        to extract destinations, keywords, scenes, and a full transcript — in Turkish or English.
    </p>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label fw-semibold">Video URL</label>
                <input @bind="_videoUrl" class="form-control" placeholder="https://..." />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Video Name (optional)</label>
                <input @bind="_videoName" class="form-control" placeholder="My Istanbul vlog" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Primary Language</label>
                <select @bind="_language" class="form-select" style="max-width:200px">
                    <option value="en">🇬🇧 English</option>
                    <option value="tr">🇹🇷 Turkish</option>
                </select>
            </div>
            <button class="btn btn-primary" @onclick="IngestVideo" disabled="@(_isLoading || string.IsNullOrWhiteSpace(_videoUrl))">
                @(_isLoading ? "Submitting…" : "🔍 Analyse Video")
            </button>
        </div>
    </div>

    @if (_errorMessage is not null)
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }

    @if (_insights is not null)
    {
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">📊 Video Insights</div>
            <div class="card-body">
                <p><strong>Video ID:</strong> <code>@_insights.VideoId</code></p>
                <p><strong>Summary:</strong> @_insights.Summary</p>

                @if (_insights.Keywords.Count > 0)
                {
                    <div class="mb-3">
                        <strong>Keywords:</strong>
                        <div class="mt-1">
                            @foreach (var kw in _insights.Keywords)
                            {
                                <span class="badge bg-secondary me-1">@kw</span>
                            }
                        </div>
                    </div>
                }

                @if (_insights.Destinations.Count > 0)
                {
                    <div class="mb-3">
                        <strong>Destinations mentioned:</strong>
                        <div class="mt-1">
                            @foreach (var dest in _insights.Destinations)
                            {
                                <span class="badge bg-success me-1">🗺️ @dest</span>
                            }
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(_insights.Transcript))
                {
                    <details class="mt-2">
                        <summary class="fw-semibold">📝 Transcript</summary>
                        <p class="mt-2 text-muted small">@_insights.Transcript</p>
                    </details>
                }

                @if (_insights.VideoId != "pending")
                {
                    <div class="mt-3">
                        <button class="btn btn-outline-primary btn-sm" @onclick="PollInsights">
                            🔄 Refresh Insights
                        </button>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private string _videoUrl = string.Empty;
    private string _videoName = string.Empty;
    private string _language = "en";
    private bool _isLoading;
    private string? _errorMessage;
    private TurkAI.Shared.Models.VideoInsights? _insights;

    private async Task IngestVideo()
    {
        if (string.IsNullOrWhiteSpace(_videoUrl)) return;
        _errorMessage = null;
        _isLoading = true;

        try
        {
            var request = new TurkAI.Shared.Models.VideoIngestionRequest
            {
                VideoUrl = _videoUrl,
                Language = _language,
                Name = _videoName
            };
            var response = await Http.PostAsJsonAsync("api/video/ingest", request);
            response.EnsureSuccessStatusCode();
            _insights = await response.Content.ReadFromJsonAsync<TurkAI.Shared.Models.VideoInsights>();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to ingest video: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task PollInsights()
    {
        if (_insights is null) return;
        _errorMessage = null;
        _isLoading = true;

        try
        {
            var response = await Http.GetAsync($"api/video/{_insights.VideoId}/insights");
            if (response.IsSuccessStatusCode)
            {
                _insights = await response.Content.ReadFromJsonAsync<TurkAI.Shared.Models.VideoInsights>();
            }
            else
            {
                _errorMessage = "Video is still being processed. Please try again in a moment.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to refresh insights: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
