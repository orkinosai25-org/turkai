@page "/"

<PageTitle>TürkAI — Your AI Turkey Travel Expert</PageTitle>

<div class="turkai-hero">
    <div class="turkai-hero-content">
        <h1 class="turkai-title">🇹🇷 TürkAI</h1>
        <p class="turkai-subtitle">Your AI-Powered Turkey Travel Expert</p>
        <p class="turkai-description">
            Plan your perfect Turkish adventure with GPT-4o&nbsp;AI. Get personalised recommendations,
            real-time translation, video insights, and expert travel guidance — in English or Turkish.
        </p>
        <div class="turkai-cta">
            <a href="/chat" class="btn btn-primary btn-lg me-2">💬 Start Chatting</a>
            <a href="/destinations" class="btn btn-outline-secondary btn-lg">🗺️ Explore Destinations</a>
        </div>
    </div>
</div>

<div class="container mt-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="feature-icon mb-3">🤖</div>
                    <h5 class="card-title">AI Travel Assistant</h5>
                    <p class="card-text">Ask anything about Türkiye. GPT-4o answers in Turkish or English with expert local knowledge.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="feature-icon mb-3">🌍</div>
                    <h5 class="card-title">Turkish ↔ English</h5>
                    <p class="card-text">Real-time translation powered by Azure AI Translator. No language barrier on your travels.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="feature-icon mb-3">🎬</div>
                    <h5 class="card-title">Video Insights</h5>
                    <p class="card-text">Submit any travel video URL and get AI-extracted destinations, keywords, and transcripts.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="feature-icon mb-3">🔊</div>
                    <h5 class="card-title">Speech &amp; Voice</h5>
                    <p class="card-text">Listen to travel tips in Turkish with Azure Neural Text-to-Speech voices.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="feature-icon mb-3">📸</div>
                    <h5 class="card-title">Image Analysis</h5>
                    <p class="card-text">Share a photo and TürkAI identifies landmarks, locations, and travel insights using Azure Computer Vision.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="feature-icon mb-3">✨</div>
                    <h5 class="card-title">Personalised for You</h5>
                    <p class="card-text">ML-powered recommendations via Azure Personalizer learn your travel style and surprise you with new destinations.</p>
                </div>
            </div>
        </div>
    </div>
</div>
