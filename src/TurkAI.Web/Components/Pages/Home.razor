@page "/"

<PageTitle>TürkiyAI — Your AI Türkiye Travel Expert</PageTitle>

<div class="turkai-hero">
    <div class="turkai-hero-content">
        <div class="mb-3">
            <img src="/images/logo.svg"
                 alt="TürkiyAI"
                 height="80"
                 class="hero-logo d-inline-block"
                 loading="eager" />
        </div>
        <p class="turkai-subtitle">Your AI-Powered Türkiye Travel Expert</p>
        <p class="turkai-description">
            Plan your perfect Turkish adventure with GPT-4o&nbsp;AI. Get personalised recommendations,
            real-time translation, video insights, and expert travel guidance — in English or Turkish.
        </p>
        <div class="turkai-cta">
            <a href="/chat"         class="btn btn-light btn-lg fw-bold">💬 Start Chatting</a>
            <a href="/register"     class="btn btn-outline-light btn-lg">✨ Sign Up Free</a>
            <a href="/destinations" class="btn btn-outline-light btn-lg opacity-75">🗺️ Explore Destinations</a>
        </div>
    </div>
</div>

<div class="container mt-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="feature-icon mb-3">🤖</div>
                    <h5 class="card-title">AI Travel Assistant</h5>
                    <p class="card-text">Ask anything about Türkiye. GPT-4o answers in Turkish or English with expert local knowledge.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="feature-icon mb-3">🌍</div>
                    <h5 class="card-title">Turkish ↔ English</h5>
                    <p class="card-text">Real-time translation powered by Azure AI Translator. No language barrier on your travels.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="feature-icon mb-3">🎬</div>
                    <h5 class="card-title">Video Insights</h5>
                    <p class="card-text">Submit any travel video URL and get AI-extracted destinations, keywords, and transcripts.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="feature-icon mb-3">🔊</div>
                    <h5 class="card-title">Speech &amp; Voice</h5>
                    <p class="card-text">Listen to travel tips in Turkish with Azure Neural Text-to-Speech voices.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="feature-icon mb-3">📸</div>
                    <h5 class="card-title">Image Analysis</h5>
                    <p class="card-text">Share a photo and TürkiyAI identifies landmarks, locations, and travel insights using Azure Computer Vision.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="feature-icon mb-3">✨</div>
                    <h5 class="card-title">Personalised for You</h5>
                    <p class="card-text">ML-powered recommendations via Azure Personalizer learn your travel style and surprise you with new destinations.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Pricing teaser -->
    <div class="row mt-5">
        <div class="col-12 text-center">
            <h2 class="fw-bold mb-2">Plans for Every Explorer</h2>
            <p class="text-muted mb-4">Start free. Upgrade for unlimited access and enterprise API integration.</p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <div class="pricing-teaser-card card shadow-sm text-start p-4" style="min-width:200px">
                    <div class="fw-bold mb-1">🆓 Free</div>
                    <div class="text-muted small mb-2">€0/month</div>
                    <div class="small">20 chats/day · Translation · Recommendations</div>
                    <a href="/register?plan=Free" class="btn btn-outline-primary btn-sm mt-3 w-100">Get Started</a>
                </div>
                <div class="pricing-teaser-card card shadow border-primary text-start p-4" style="min-width:200px;border-width:2px!important">
                    <div class="fw-bold mb-1">⭐ Professional</div>
                    <div class="text-muted small mb-2">€19/month</div>
                    <div class="small">Unlimited · Voice · Video · Priority AI</div>
                    <a href="/register?plan=Professional" class="btn btn-primary btn-sm mt-3 w-100">Start Trial</a>
                </div>
                <div class="pricing-teaser-card card shadow-sm text-start p-4" style="min-width:200px">
                    <div class="fw-bold mb-1">🏢 Enterprise</div>
                    <div class="text-muted small mb-2">€99/month</div>
                    <div class="small">API access · Embeddable chat · Custom training</div>
                    <a href="/register?plan=Enterprise" class="btn btn-warning btn-sm mt-3 w-100 text-dark fw-bold">Contact Sales</a>
                </div>
            </div>
            <a href="/pricing" class="btn btn-link mt-3">View full pricing →</a>
        </div>
    </div>
</div>
